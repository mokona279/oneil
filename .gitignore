# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Packaging / build
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments (venv는 이웃 daytrading 레포 공유 — 여기엔 없음)
.venv/
venv/
env/
ENV/

# 자격증명 (KRX_ID/KRX_PW 등) — 절대 커밋 금지
.env
.env.*
!.env.example

# Test / coverage / type caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.hypothesis/

# Jupyter
.ipynb_checkpoints/

# 백테스트 산출물 (재현 가능 — 커밋하지 않음. 골든파일만 예외적으로 추가)
outputs/
results/
*.parquet
out/

# 대용량 실데이터 (data_example/의 소형 스모크 데이터는 예외적으로 커밋)
# 루트 앵커(/) — src/oneil_bt/data/ 소스 패키지는 제외하지 않도록
/data/
!/data_example/

# 계좌 상태(현금·보유종목) — 개인정보, 커밋 금지 (템플릿만 예외)
/state/*
!/state/holdings.example.csv

# IDE / editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
